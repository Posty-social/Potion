BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=replace-with-output-from-better-auth-cli-secret
TRUSTED_ORIGINS=http://localhost:3001

# Required for Drizzle Kit remote D1 operations.
CLOUDFLARE_ACCOUNT_ID=replace-me
CLOUDFLARE_DATABASE_ID=replace-me
CLOUDFLARE_API_TOKEN=replace-me

# Production deploy variables are set in GitHub Actions, not committed here.
APP_DOMAIN=potion.example.com
D1_DATABASE_NAME=potion-db
R2_BUCKET_NAME=potion-assets
PULUMI_STATE_BUCKET=potion-pulumi-state

# Optional: comma-separated emails. When set (as a GitHub Actions variable),
# the deployed app is placed behind Cloudflare Zero Trust (Access) and only
# these users can reach it. Unset = no Access gate.
ZERO_TRUST_EMAILS=

# Optional OAuth providers.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Required for R2 presigned URLs in production.
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
